# AetherVex Backend — Environment Variables
# Copy this file to .env and fill in your values

PORT=3001
NODE_ENV=development

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_here

# Database path (relative to backend dir)
DB_PATH=./data/aethervex.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,https://aethervex.github.io

# Optional: Stripe secret key for real payments
STRIPE_SECRET_KEY=

# Optional: Mercado Pago access token
MP_ACCESS_TOKEN=
